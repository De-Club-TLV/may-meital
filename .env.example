# Trigger.dev webhook the form POSTs to on submit
# (lives in the De Club General project)
TRIGGER_WEBHOOK_URL=your_trigger_webhook_url_here

# Arbox purchase page the user is redirected to after submit
ARBOX_PURCHASE_URL=https://3ol1r9sb.web.arboxapp.com/shop/490714?whitelabel=DeClub&lang=he&location=21230

# Endpoint the form polls on load to check if signups are still open
# Returns { open: true|false }. When 30 paid signups are reached, the
# General project flips this to false and the form renders "sold out".
FORM_STATUS_URL=your_form_status_url_here

# Netlify site ID (optional, for CLI deploys)
NETLIFY_SITE_ID=your_netlify_site_id_here
