# --- Required by netlify/functions/submit-signup.ts ---

# Shared HMAC secret. Must match the value in script.js (HMAC_SECRET constant).
# Browser-visible; the server-side check is the actual gate. Rotate by updating
# both this env var and the constant in script.js.
MAY_MEITAL_HMAC_SECRET=your_hmac_secret_here

# Trigger.dev production secret key (Bearer token for the Trigger.dev REST API).
# Same key the General project uses; scoped to the De Club Trigger.dev project.
TRIGGER_PROD_SECRET_KEY=tr_prod_your_key_here

# Telegram alert credentials. submit-signup pings this group whenever a real
# (post-HMAC) submission fails. The /health-check skill scans this group for
# the keyword "error" and turns each alert into a ticket. Re-use the same bot
# token as the De Club /General/ project. Chat id is the De Club Alerts group.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALERT_CHAT_ID=-1003599876238

# --- Required by netlify/functions/form-status.ts ---

# "true" while signups are open, "false" once we've hit the 30-paid cap.
# The /General/ Trigger.dev project flips this via the Netlify API and
# triggers a redeploy so the form re-reads the value.
FORM_OPEN=true

# --- Optional ---

# Netlify site ID (only needed for CLI deploys / local dev tooling).
NETLIFY_SITE_ID=your_netlify_site_id_here
